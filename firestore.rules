rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function groupExists(groupId) {
      return exists(/databases/$(database)/documents/groups/$(groupId));
    }
    
    function getGroupData(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data;
    }
    
    function isAdmin() {
      return request.auth != null && request.auth.uid == '605oNyF1miUumLGMgEnaGGD0Lyh2';
    }

    function isGroupMember(groupId) {
      return isAdmin() || (request.auth != null && groupExists(groupId)
        && request.auth.uid in getGroupData(groupId).members);
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    match /groups/{groupId} {
      allow read: if isAdmin() || (request.auth != null
        && (resource.data.inviteLinkEnabled == true
            || request.auth.uid in resource.data.members
            || request.auth.token.phone_number in resource.data.pendingPhones));
            
      allow create: if request.auth != null;

      allow update: if request.auth != null
        && (
          (request.auth.uid == resource.data.creatorId
           && request.resource.data.creatorId == resource.data.creatorId
           && request.resource.data.activeCycleId == resource.data.activeCycleId
           && (request.resource.data.cycleStatus == resource.data.cycleStatus ||
               (resource.data.cycleStatus == 'active' && request.resource.data.cycleStatus == 'settling') ||
               (resource.data.cycleStatus == 'settling' && request.resource.data.cycleStatus == 'active'))
          )
          ||
          (request.auth.uid != resource.data.creatorId
           && (request.auth.uid in resource.data.members || request.auth.token.phone_number in resource.data.pendingPhones)
           && request.resource.data.creatorId == resource.data.creatorId
           && request.resource.data.activeCycleId == resource.data.activeCycleId
           && request.resource.data.cycleStatus == resource.data.cycleStatus
           && request.resource.data.inviteLinkToken == resource.data.inviteLinkToken
           && request.resource.data.inviteLinkEnabled == resource.data.inviteLinkEnabled)
        );

      allow delete: if request.auth != null && request.auth.uid == resource.data.creatorId;
    }

    match /groups/{groupId}/expenses/{expenseId} {
      allow read: if isGroupMember(groupId);
      allow create: if isGroupMember(groupId) 
        && getGroupData(groupId).cycleStatus == 'active'
        && request.resource.data.createdById == request.auth.uid;
      allow update, delete: if isGroupMember(groupId)
        && getGroupData(groupId).cycleStatus == 'active'
        && (request.auth.uid == resource.data.createdById || request.auth.uid == getGroupData(groupId).creatorId);
    }

    match /groups/{groupId}/settled_cycles/{cycleId} {
      allow read: if isGroupMember(groupId);
      allow create, update, delete: if false;
    }

    match /groups/{groupId}/settled_cycles/{cycleId}/expenses/{expenseId} {
      allow read: if isGroupMember(groupId);
      allow create, update, delete: if false;
    }

    match /groups/{groupId}/system_messages/{messageId} {
      allow read, create: if isGroupMember(groupId);
      allow update, delete: if false;
    }

    match /groups/{groupId}/expense_revisions/{revisionId} {
      allow read, create: if isGroupMember(groupId);
      allow update, delete: if false;
    }

    match /groups/{groupId}/deleted_expenses/{expenseId} {
      allow read: if isGroupMember(groupId);
      allow create: if isGroupMember(groupId) && getGroupData(groupId).cycleStatus == 'active';
      allow update, delete: if false;
    }

    match /groups/{groupId}/payment_attempts/{attemptId} {
      allow read: if isGroupMember(groupId);
      
      allow create: if isGroupMember(groupId)
        && getGroupData(groupId).cycleStatus == 'settling'
        && request.resource.data.fromMemberId == request.auth.uid
        && !('status' in request.resource.data)
        && !('confirmedByPayer' in request.resource.data)
        && !('confirmedByReceiver' in request.resource.data)
        && !('disputed' in request.resource.data);
      
      allow update: if isGroupMember(groupId) && (
        (request.auth.uid == resource.data.fromMemberId && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['confirmedByPayer', 'paidVia', 'upiTransactionId', 'upiResponseCode', 'initiatedAt', 'confirmedAt'])
        ) || 
        (request.auth.uid == resource.data.toMemberId && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['confirmedByReceiver', 'disputed', 'confirmedAt'])
        )
      ) && 
      request.resource.data.amountMinor == resource.data.amountMinor &&
      request.resource.data.fromMemberId == resource.data.fromMemberId &&
      request.resource.data.toMemberId == resource.data.toMemberId &&
      request.resource.data.cycleId == resource.data.cycleId &&
      !('status' in request.resource.data.diff(resource.data).affectedKeys());
      
      allow delete: if false;
    }

    match /groups/{groupId}/settlement_events/{eventId} {
      allow read, create: if isGroupMember(groupId);
      allow update, delete: if false;
    }
  }
}
